# Скопируйте в .env при необходимости
# DJANGO_SECRET_KEY=...
# DJANGO_DEBUG=1
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CORS_ORIGINS=https://your-frontend.example

# Этот файл автоматически читается из settings.py (python-dotenv).
# Общий выбор провайдера: auto | sms_to | twilio | mock
# SMS_PROVIDER=auto
#
# SMS.to (реальная отправка 4-значного кода на телефон при регистрации/входе)
# Можно использовать любое из двух имён (предпочтительно SMSTO_API_KEY):
# SMSTO_API_KEY=your_sms_to_api_key
# SMSTO_API_TOKEN=your_sms_to_api_key
# SMSTO_SENDER_ID=SMSto
# SMSTO_BASE_URL=https://api.sms.to
# SMS_SSL_VERIFY=1
# SMS_USE_SYSTEM_PROXY=0
#
# Twilio (fallback или основной провайдер)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx
#
# Telegram bot для заказов и входа
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=your_bot_username
# TELEGRAM_CHAT_ID=
# TELEGRAM_SSL_VERIFY=1
# TELEGRAM_USE_SYSTEM_PROXY=0
# BUKHARA_SERVICE_RADIUS_KM=45
