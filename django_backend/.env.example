# Скопируйте в .env при необходимости
# DJANGO_SECRET_KEY=...
# DJANGO_DEBUG=1
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CORS_ORIGINS=https://your-frontend.example

# Этот файл автоматически читается из settings.py (python-dotenv).
# SMS через Twilio (реальная отправка 4-значного кода на телефон при регистрации/входе)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx
