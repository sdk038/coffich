# Скопируйте в .env при необходимости
# DJANGO_SECRET_KEY=...
# DJANGO_DEBUG=1
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CORS_ORIGINS=https://your-frontend.example

# Этот файл автоматически читается из settings.py (python-dotenv).
# SMS.to (реальная отправка 4-значного кода на телефон при регистрации/входе)
# SMSTO_API_KEY=
# SMSTO_SENDER_ID=SMSto
# SMSTO_BASE_URL=https://api.sms.to
