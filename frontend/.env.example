# Порт должен совпадать с `python manage.py runserver` (по умолчанию 8000).
# Если Django слушает другой порт (например 8001), скопируйте в `.env.development.local`:
# REACT_APP_PROXY_TARGET=http://127.0.0.1:8001
#
# Прямые запросы к API без прокси (тогда настройте CORS в Django):
# REACT_APP_API_URL=http://127.0.0.1:8000
